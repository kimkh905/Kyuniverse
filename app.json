{
  "expo": {
    "name": "Korean English Flashcards",
    "slug": "korean-english-flashcards",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "koreanenglishflashcards",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff7ef"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kimkh905.koreanenglishflashcards"
    },
    "android": {
      "package": "com.kimkh905.koreanenglishflashcards",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fff7ef"
      }
    },
    "plugins": [
      "expo-notifications"
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single",
      "bundler": "metro"
    }
  }
}
